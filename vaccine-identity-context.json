{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "vax": "https://example.org/vaccine-context#",

    "VaccinationCertificate": {
      "@id": "vax:VaccinationCertificate"
    },

    "issuingCountry": "vax:issuingCountry",

    "issuedAt": {
      "@id": "vax:issuedAt",
      "@type": "xsd:integer"
    },

    "healthCertificate": "vax:healthCertificate",
    
    "name": "schema:name",

    "sex": "schema:gender",

    "dateOfBirth": {
      "@id": "schema:birthDate",
      "@type": "xsd:date"
    },
    
    "nationalId": "vax:nationalId",

    "nationalIdType": "vax:nationalIdType",

    "nationality": "vax:nationality",

    "vaccinations": {
      "@id": "vax:vaccinations",
      "@container": "@set"
    },

    "data": {
      "@id": "vax:data",
      "@container": "@set"
    },

    "url": "vax:url",

    "flag": "vax:flag",

    "exp": {
      "@id": "vax:exp",
      "@type": "xsd:date"
     },

    "key": "vax:key",

    "label": "vax:label",
    
    "batchOrIdentifier": "vax:batchOrIdentifier",

    "certificateNumber": "vax:certificateNumber",
    
    "vaccinationDate": {
      "@id": "vax:vaccinationDate",
      "@type": "xsd:date"
     },

    "certificateIssuer": "vax:certificateIssuer",
    
    "vaccineProduct": "vax:vaccineProduct",

    "validityPeriodEndDate": "vax:validityPeriodEndDate",

    "validFrom": {
      "@id": "vax:validFrom",
      "@type": "xsd:date"
    },

    "expirationTime": {
      "@id": "vax:expirationTime",
      "@type": "xsd:date"
     }
  }
}
