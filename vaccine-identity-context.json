{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "vax": "https://example.org/vaccine-context#",

    "VaccinationCertificate": {
      "@id": "vax:VaccinationCertificate"
    },

    "name": {
      "@id": "vax:name",
      "@container": "@set"
    },
    
    "familyName": "schema:familyName",

    "givenName": "schema:givenName",

    "familyNameTransliterated": "vax:familyNameTransliterated",

    "givenNameTransliterated": "vax:givenNameTransliterated",

    "dateOfBirth": {
      "@id": "schema:birthDate",
      "@type": "xsd:date"
    },

    "vaccinations": {
      "@id": "vax:vaccinations",
      "@container": "@set"
    },

    "targetDisease": "vax:targetDisease",

    "vaccineOrProphylaxis": "vax:vaccineOrProphylaxis",

    "medicinalProduct": "schema:drug",

    "manufacturer": "schema:manufacturer",

    "doseNumber": {
      "@id": "vax:doseNumber",
      "@type": "xsd:integer"
    },

    "totalSeriesOfDoses": {
      "@id": "vax:totalSeriesOfDoses",
      "@type": "xsd:integer"
    },

    "vaccinationDate": {
      "@id": "vax:vaccinationDate",
      "@type": "xsd:date"
    },

    "countryOfVaccination": "schema:addressCountry",

    "certificateIssuer": "schema:issuer",

    "certificateIdentifier": "schema:identifier"
  }
}
